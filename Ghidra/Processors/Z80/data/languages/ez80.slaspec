    push24(&:3 inst_next);
	call Addr24;
}

:RET^suf                is ADL=0 & suf & op0_8=0xc9 {
	pop16(PC);
	ptr:$(PTRSIZE) = PC;
	return [ptr];
}

:RET^suf                is ADL=1 & suf & op0_8=0xc9 {
	pop24(PC);
	ptr:$(PTRSIZE) = PC;
	return [ptr];
}

