}

:SLA ixMem8         is op0_8=0x0dd; op0_8=0xcb; ixMem8; op0_8=0x26 {
	val:1 = ixMem8;
	CF = (val >> 7);
	val = val << 1;
	setResultFlags(val);
	ixMem8 = val;
	HF = 0;
