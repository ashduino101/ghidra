}

:SRA reg0_3         is op0_8=0x0cb; op6_2=0x0 & bits3_3=0x5 & reg0_3 {
	local _val = reg0_3;
	CF = (_val & 1);
	_val = _val s>> 1;
	reg0_3 = _val;
	setResultFlags(_val);
	HF = 0;
	setParity(_val);
	NF = 0;
}

:SRA (HL)           is op0_8=0x0cb & HL; op0_8=0x2e {
	val:1 = 0;
	MemRead(val,HL);
	CF = (val & 1);
	val = val s>> 1;
	setResultFlags(val);
	MemStore(HL,val);
	HF = 0;
	setParity(val);
	NF = 0;
}

:SRA ixMem8         is op0_8=0x0dd; op0_8=0xcb; ixMem8; op0_8=0x2e {
	val:1 = ixMem8;
	CF = (val & 1);
	val = val s>> 1;
	setResultFlags(val);
	ixMem8 = val;
	HF = 0;
	setParity(val);
	NF = 0;
}

:SRA iyMem8         is op0_8=0x0fd; op0_8=0xcb; iyMem8; op0_8=0x2e {
	val:1 = iyMem8;
	CF = (val & 1);
	val = val s>> 1;
	setResultFlags(val);
	iyMem8 = val;
	HF = 0;
	setParity(val);
	NF = 0;
}

:SRL reg0_3         is op0_8=0x0cb; op6_2=0x0 & bits3_3=0x7 & reg0_3 {
	local val = reg0_3;
	CF = (val & 1);
	val = val >> 1;
	reg0_3 = val;
	setResultFlags(val);
	HF = 0;
	setParity(val);
	NF = 0;
}

:SRL (HL)           is op0_8=0x0cb & HL; op0_8=0x3e {
	val:1 = 0;
	MemRead(val,HL);
	CF = (val & 1);
	val = val >> 1;
	setResultFlags(val);
	MemStore(HL,val);
	HF = 0;
	setParity(val);
	NF = 0;
}

:SRL ixMem8         is op0_8=0x0dd; op0_8=0xcb; ixMem8; op0_8=0x3e {
	val:1 = ixMem8;
	CF = (val & 1);
	val = val >> 1;
	setResultFlags(val);
	ixMem8 = val;
