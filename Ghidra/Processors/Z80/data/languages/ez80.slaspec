}

:SLA (HL)           is op0_8=0x0cb & HL; op0_8=0x26 {
	val:1 = 0;
	MemRead(val,HL);
	CF = (val >> 7);
	val = val << 1;
	setResultFlags(val);
	MemStore(HL,val);
	HF = 0;
