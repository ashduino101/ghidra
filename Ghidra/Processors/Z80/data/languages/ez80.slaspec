}

:RES bits3_3,iyMem8 is op0_8=0xfd; op0_8=0xcb; iyMem8; op6_2=0x2 & bits3_3 & bits0_3=0x6 {
	mask:1 = ~(1 << bits3_3);
	val:1 = iyMem8;
	iyMem8 = val & mask;
}

:JP^suf Addr          is suf & op0_8=0xc3; Addr [ globalset(Addr,ADL); ] {
	goto Addr;
}

:JP^suf cc,Addr       is suf & op6_2=0x3 & cc & bits0_3=0x2; Addr [ globalset(Addr,ADL); ] {
	if (cc) goto Addr;
}

:JR RelAddr8        is op0_8=0x18; RelAddr8 {
	goto RelAddr8;
}

:JR cc2,RelAddr8    is op6_2=0x0 & cc2 & bits0_3=0x0; RelAddr8 {
	if (cc2) goto RelAddr8;
}

:JP^suf (HL)            is suf & op0_8=0xe9 & ADL=0 & HL [ globalset(inst_next,ADL); ] {
	off:2 = (zext(H) << 8) | zext(L);
	JumpToLoc16(off);
}

:JP^suf (HL)            is suf & op0_8=0xe9 & ADL=1 & HL {
	off:3 = (zext(HLU) << 16) | (zext(H) << 8) | zext(L);
	JumpToLoc24(off);
}

# FIXME: these should set the ADL mode
:JP^suf (IX)            is suf & op0_8=0xdd & ADL=0 & IX; op0_8=0xe9 {
	JumpToLoc16(IX:2);
}

:JP^suf (IX)            is suf & op0_8=0xdd & ADL=1 & IX; op0_8=0xe9 {
	JumpToLoc24(IX);
}

:JP^suf (IY)            is suf & op0_8=0xfd & ADL=0 & IY; op0_8=0xe9 {
	JumpToLoc16(IY:2);
}

:JP^suf (IY)            is suf & op0_8=0xfd & ADL=1 & IY; op0_8=0xe9 {
	JumpToLoc24(IY);
}

:DJNZ RelAddr8      is op0_8=0x10; RelAddr8 {
