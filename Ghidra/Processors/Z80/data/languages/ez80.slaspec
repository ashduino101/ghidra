:OUTI               is op0_8=0xed & IOAddrBC; op0_8=0xa3 {
	local test = B - 1;
	B = test;
	val:1 = 0;
	MemRead(val,HL);

	out(IOAddrBC, val);
	HL = HL + 1;
	ZF = (test == 0);
	NF = (test s< 0);
}

:OUTI2               is op0_8=0xed & IOAddrBC; op0_8=0xa4 {
