}

:SRL iyMem8         is op0_8=0x0fd; op0_8=0xcb; iyMem8; op0_8=0x3e {
	val:1 = iyMem8;
	CF = (val & 1);
	val = val >> 1;
	setResultFlags(val);
	iyMem8 = val;
